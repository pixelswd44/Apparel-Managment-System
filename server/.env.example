# ── Server config ──────────────────────────────────────────────────────────
PORT=3001
JWT_SECRET=replace-with-a-long-random-string

# ── App URL (used in password reset links) ──────────────────────────────────
# In dev: http://localhost:5173
# In prod: https://your-domain.com
APP_URL=http://localhost:5173

# ── Email / SMTP (for password reset) ───────────────────────────────────────
# Leave these blank to fall back to on-screen reset links (no email).
#
# Gmail setup (FREE — recommended):
#   1. Enable 2-Step Verification at https://myaccount.google.com/security
#   2. Generate an "App Password" at https://myaccount.google.com/apppasswords
#      (pick "Mail" + "Other" → name it "Apparel CRM")
#   3. Use the 16-character app password below (NOT your real Gmail password)
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="Apparel CRM" <your-email@gmail.com>

# ── Other SMTP providers ────────────────────────────────────────────────────
# Outlook / Office 365:    smtp.office365.com  port 587
# Yahoo:                   smtp.mail.yahoo.com port 587
# Brevo (free 300/day):    smtp-relay.brevo.com port 587
# Your own domain:         smtp.your-domain.com (ask your hosting provider)
