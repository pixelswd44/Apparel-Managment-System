# Dependencies
node_modules/
client/node_modules/
server/node_modules/

# Build output
client/dist/
client/dist-ssr/

# Database (local data — never commit)
server/apparel.db
server/apparel.db-shm
server/apparel.db-wal
server/src/db/*.db
server/src/db/*.db-shm
server/src/db/*.db-wal

# Uploaded files (user media — never commit)
server/uploads/*
!server/uploads/.gitkeep

# Logs
server/server.log
server/*.log
client/vite.log
*.log
npm-debug.log*

# Environment variables
.env
.env.local
.env.*.local
server/.env

# Temp / wipe scripts
server/wipe.mjs

# OS
.DS_Store
Thumbs.db
desktop.ini

# Junk / accidental files
server/Apparel*
server/C*.json
*.db
*.db-shm
*.db-wal

# Editor
.vscode/
.idea/
*.swp
*.swo

# Vite cache
client/.vite/
